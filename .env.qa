# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zyncjobs
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/zyncjobs

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://qa.zyncjobs.com,http://localhost:5173

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Anthropic API Configuration
PRIMARY_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Backup API Configuration
USE_FALLBACK_AI=true
OPENAI_API_KEY=your_openai_api_key_here

# Pinecone Vector Database Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=trinity-jobs

# Clearbit API Configuration (Optional)
CLEARBIT_API_KEY=your_clearbit_api_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@example.com
SMTP_PASSWORD=your_app_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SESSION_SECRET=your_session_secret_here

# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here

# Zoom Configuration
ZOOM_ACCOUNT_ID=your_zoom_account_id_here
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here
